# Deployed Sepolia contract addresses
NEXT_PUBLIC_ARTISAN_REGISTRY_ADDRESS=0xYourArtisanRegistryAddress
NEXT_PUBLIC_PRODUCT_REGISTRY_ADDRESS=0xYourProductRegistryAddress

# Public RPC endpoint for Sepolia reads/writes
NEXT_PUBLIC_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Websocket RPC endpoint for realtime monitor events
NEXT_PUBLIC_WS_RPC_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Optional model inference API endpoint for craft scoring
NEXT_PUBLIC_CRAFT_MODEL_INFERENCE_URL=https://your-api.example.com/infer/craft-detector

# Public deployment URL shown in footer
NEXT_PUBLIC_VERCEL_URL=https://your-app.vercel.app
